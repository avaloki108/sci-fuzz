# Sci-Fuzz Configuration
# Copy this to .env and populate the values

# Required for 'audit' subcommand and on-chain forking
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY

# Required for automated ABI retrieval from Etherscan
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_KEY

# Optional: default block number to fork from
# FORK_BLOCK_NUMBER=19000000

# Optional: default timeout (seconds)
# TIMEOUT=3600
